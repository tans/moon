# MOON Application Configuration
# Copy this file to .env and fill in the values

# Server Configuration
PORT=8787
NODE_ENV=production

# Database (optional, defaults to ./data/moon.sqlite)
SQLITE_PATH=./data/moon.sqlite

# JWT Secret - REQUIRED, must be a secure random string in production
# Generate with: openssl rand -base64 32
JWT_SECRET=moon-secret-key-change-in-production

# OnePay Configuration
ONEPAY_BASE_URL=https://onepay.minapp.xin
PAYMENT_NOTIFY_URL=https://your-app-domain.com/api/payment/notify

# AI Provider API Keys - configure at least one provider
# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google AI
GOOGLE_API_KEY=

# Kimi (Moonshot)
KIMI_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# Qwen (Alibaba)
QWEN_API_KEY=